# Copy to scripts/docker-ghcr.env (gitignored) or export before build/push.
#
# GHCR image: ghcr.io/punhlaingsoftwareengineering/employee-portal:<tag>

GHCR_REGISTRY=ghcr.io
GHCR_ORG=punhlaingsoftwareengineering
GHCR_IMAGE=employee-portal

# GitHub username for `docker login` (not the org name)
GHCR_USER=your-github-username

# PAT with read:packages + write:packages (never commit)
# GHCR_TOKEN=ghp_...
