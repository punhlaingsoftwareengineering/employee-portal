# Drizzle — local PostgreSQL
# No surrounding quotes on DATABASE_URL (Docker --env-file keeps literal " marks and breaks parsing).
# If the password contains @, encode it as %40 (e.g. secret@123 → secret%40123).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/employee_portal

# Shared Better Auth DB (defaults to DATABASE_URL). PHH-DRIVE uses the same URL.
# AUTH_DATABASE_URL=postgres://postgres:postgres@localhost:5432/employee_portal

# --- Public URLs (local dev) ---
ORIGIN=http://portal.local.test
DRIVE_ORIGIN=http://drive.local.test
# Team API key for portal media uploads (server-side only; znltv_… with drive.read/write/share)
# DRIVE_TEAM_API_KEY=znltv_...
# DRIVE_STORAGE_PROVIDER=local
AUTH_COOKIE_DOMAIN=.local.test
# Optional override; DRIVE_ORIGIN is trusted by default for ?redirectTo=
# PORTAL_TRUSTED_REDIRECT_ORIGINS=http://drive.local.test

# --- Public URLs (production) ---
# ORIGIN=https://phh.com
# DRIVE_ORIGIN=https://office.drive.phh.com
# AUTH_COOKIE_DOMAIN=.phh.com
# PORTAL_TRUSTED_REDIRECT_ORIGINS=https://office.drive.phh.com

# Caddy reverse proxy (employee-portal generates Caddyfile.generated from ORIGIN + DRIVE_ORIGIN)
# CADDY_PORTAL_UPSTREAM=localhost:1027
# CADDY_DRIVE_UPSTREAM=localhost:1025
# CADDY_TLS=auto   # force HTTPS blocks (default: infer from ORIGIN/DRIVE_ORIGIN scheme)
# CADDY_TLS=off    # force HTTP blocks (local dev)

# Vite dev server allowlist (optional; defaults to AUTH_COOKIE_DOMAIN or ORIGIN hostnames)
# ALLOWED_HOSTS=.phh.com

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# Session lifetime and cookies (optional — SSO defaults: 7d expiry, 30m rolling refresh & cache)
# AUTH_SESSION_EXPIRES_IN="7d"
# AUTH_SESSION_UPDATE_AGE="30m"
# AUTH_SESSION_COOKIE_CACHE_ENABLED="true"
# AUTH_SESSION_COOKIE_CACHE_MAX_AGE="30m"
# AUTH_SESSION_SECURE_COOKIES="true"
# SMTP (auth OTP emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Employee Portal <noreply@example.com>"
