{
	"nodeModulesDir": "auto",
	"tasks": {
		"dev": "vite dev --host 0.0.0.0 --port 1027",
		"build": "vite build",
		"preview": "vite preview --host 0.0.0.0 --port 1027",
		"start": "node build/index.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "deno task test:unit -- --run && deno task test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/schema/auth.schema.ts --yes"
	}
}
